# Copy to `.env` (gitignored) and load it — `set -a; source .env; set +a`.
#
# Point Triggerlane at a network Worklane broker backend (`--broker postgres|redis`)
# instead of the embedded SQLite default. These match the local docker-compose.yml
# services and are LOCAL, NON-SECRET endpoints. See the README "Configuration" table
# for the full TRIGGERLANE_* set (event store, retention, auth, submission, …).
TRIGGERLANE_WORKLANE_BROKER=postgres
TRIGGERLANE_WORKLANE_URL=postgres://triggerlane:triggerlane@localhost:55432/triggerlane

# For the Redis broker instead (run it with `maxmemory-policy noeviction`):
# TRIGGERLANE_WORKLANE_BROKER=redis
# TRIGGERLANE_WORKLANE_URL=redis://localhost:56379
